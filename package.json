{
  "name": "intention-hint",
  "version": "2026.5.4",
  "type": "module",
  "files": [
    "dist",
    "intents/**",
    "package.json",
    "openclaw.plugin.json",
    "README.md",
    "skills/**"
  ],
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "compat": {
      "pluginApi": ">=2026.5.4",
      "minGatewayVersion": "2026.5.4"
    },
    "build": {
      "openclawVersion": "2026.5.4",
      "pluginSdkVersion": "2026.5.4"
    }
  },
  "scripts": {
    "build": "bun build ./index.ts --outdir ./dist --target node",
    "test": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "format": "bunx prettier --write ."
  },
  "dependencies": {
    "gray-matter": "^4.0.3"
  },
  "devDependencies": {
    "openclaw": "^2026.5.4",
    "typescript": "^5.8.3",
    "vitest": "^4.1.5"
  }
}
