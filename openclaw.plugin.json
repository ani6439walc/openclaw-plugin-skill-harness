{
  "id": "skill-harness",
  "name": "Skill Harness",
  "description": "Pre-scans user intent before replies and injects routing hints via before_prompt_build hook.",
  "activation": {
    "onStartup": true
  },
  "contracts": {
    "tools": ["skill_harness_evolution"]
  },
  "commandAliases": [
    {
      "name": "skill-harness",
      "kind": "runtime-slash"
    }
  ],
  "skills": ["./skills"],
  "uiHints": {
    "model": {
      "label": "Scanner Model",
      "help": "Lightweight model for the intention scanner (e.g. google/gemini-3-flash). Leave empty to use the agent's default model."
    },
    "thinking": {
      "label": "Scanner Thinking",
      "help": "Thinking level for the intent classifier sub-agent."
    },
    "lowThinkingMode": {
      "label": "Low Thinking Mode",
      "help": "Controls scanner behavior when the main agent uses off, minimal, or low thinking."
    },
    "timeoutMs": {
      "label": "Scanner Timeout",
      "help": "Budget in milliseconds for each intention scanner sub-agent run."
    }
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "allowedChatTypes": {
        "type": "array",
        "items": {
          "type": "string",
          "enum": ["direct", "group", "channel", "explicit"]
        },
        "description": "Which chat types are eligible.",
        "default": ["direct"]
      },
      "allowedChatIds": {
        "type": "array",
        "items": { "type": "string" },
        "description": "Allow-list of chat IDs.",
        "default": []
      },
      "deniedChatIds": {
        "type": "array",
        "items": { "type": "string" },
        "description": "Deny-list of chat IDs.",
        "default": []
      },
      "agents": {
        "type": "array",
        "items": { "type": "string" },
        "description": "Agent IDs eligible for intention scanning.",
        "default": ["main"]
      },
      "intentDeny": {
        "type": "object",
        "description": "Per-agent deny-list for intent IDs injected into the intention classifier. Object keys are agent IDs or wildcard patterns; values are arrays of intent ID or wildcard patterns.",
        "additionalProperties": {
          "type": "array",
          "items": { "type": "string" }
        },
        "default": {}
      },
      "model": {
        "type": "string",
        "description": "Lightweight model for the intention scanner (e.g. google/gemini-3-flash). If null, falls back to the agent's default model.",
        "default": null
      },
      "modelFallback": {
        "type": "string",
        "description": "Fallback model when config.model cannot be resolved.",
        "default": null
      },
      "thinking": {
        "type": "string",
        "enum": [
          "off",
          "minimal",
          "low",
          "medium",
          "high",
          "xhigh",
          "adaptive",
          "max"
        ],
        "description": "Thinking level for the intent classifier sub-agent.",
        "default": "medium"
      },
      "lowThinkingMode": {
        "type": "string",
        "enum": ["fastpath-only", "full", "off"],
        "description": "Behavior when the main agent uses off, minimal, or low thinking. fastpath-only preserves deterministic exact keyword hints but skips all LLM scanner sub-agents; full keeps the full pipeline; off disables the plugin for low-thinking turns.",
        "default": "fastpath-only"
      },
      "timeoutMs": {
        "type": "integer",
        "minimum": 250,
        "maximum": 120000,
        "description": "Budget in milliseconds for each intention scanner sub-agent run.",
        "default": 3000
      },
      "queryMode": {
        "type": "string",
        "enum": ["message", "recent", "full"],
        "description": "Context sent to scanner: latest message only, recent turns, or full history.",
        "default": "recent"
      },
      "contextWindow": {
        "type": "object",
        "description": "Turn and character limits for recent conversation context.",
        "additionalProperties": false,
        "properties": {
          "user": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "turns": {
                "type": "integer",
                "minimum": 0,
                "maximum": 20,
                "default": 5
              },
              "chars": {
                "type": "integer",
                "minimum": 40,
                "maximum": 1000,
                "default": 220
              }
            }
          },
          "assistant": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "turns": {
                "type": "integer",
                "minimum": 0,
                "maximum": 10,
                "default": 5
              },
              "chars": {
                "type": "integer",
                "minimum": 40,
                "maximum": 1000,
                "default": 180
              }
            }
          }
        },
        "default": {}
      },
      "complexityPrompts": {
        "type": "object",
        "description": "Custom instruction-generation guidance for each complexity level.",
        "properties": {
          "low": {
            "type": "string",
            "description": "Custom prompt for low-complexity tasks (simple, quick questions).",
            "default": ""
          },
          "medium": {
            "type": "string",
            "description": "Custom prompt for medium-complexity tasks (standard multi-step work).",
            "default": ""
          },
          "high": {
            "type": "string",
            "description": "Custom prompt for high-complexity tasks (complex multi-file changes, architecture decisions).",
            "default": ""
          }
        },
        "additionalProperties": false,
        "default": {}
      },
      "instruction": {
        "type": "object",
        "description": "Optional instruction writer hints injected after intent classification. When disabled, only available domain skills are injected and generated hints are skipped.",
        "additionalProperties": false,
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": true
          },
          "model": {
            "type": "string",
            "description": "Dedicated model for instruction writer hints."
          },
          "modelFallback": {
            "type": "string",
            "description": "Fallback model when the primary instruction writer model cannot be resolved."
          },
          "thinking": {
            "type": "string",
            "enum": [
              "off",
              "minimal",
              "low",
              "medium",
              "high",
              "xhigh",
              "adaptive",
              "max"
            ],
            "description": "Thinking level for the instruction writer sub-agent.",
            "default": "medium"
          },
          "timeoutMs": {
            "type": "integer",
            "minimum": 250,
            "maximum": 600000,
            "default": 30000
          }
        },
        "default": {}
      },
      "evolution": {
        "type": "object",
        "description": "Optional post-turn Intent Evolution reviews and plugin-local backlog.",
        "additionalProperties": false,
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": false
          },
          "model": {
            "type": "string",
            "description": "Dedicated model for Evolution reviews."
          },
          "modelFallback": {
            "type": "string",
            "description": "Fallback model retried when the primary Evolution review model fails."
          },
          "thinking": {
            "type": "string",
            "enum": [
              "off",
              "minimal",
              "low",
              "medium",
              "high",
              "xhigh",
              "adaptive",
              "max"
            ],
            "description": "Thinking level for the Evolution review sub-agent.",
            "default": "medium"
          },
          "timeoutMs": {
            "type": "integer",
            "minimum": 250,
            "maximum": 600000,
            "default": 30000
          },
          "triggers": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "skillCandidate": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "enabled": { "type": "boolean", "default": true },
                  "toolCalls": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 100,
                    "default": 5
                  }
                }
              },
              "processGap": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "enabled": { "type": "boolean", "default": true },
                  "toolFailures": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 100,
                    "default": 2
                  }
                }
              },
              "successfulPattern": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "enabled": { "type": "boolean", "default": true },
                  "toolCalls": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 100,
                    "default": 5
                  },
                  "keywords": {
                    "type": "array",
                    "items": { "type": "string" },
                    "description": "Deprecated seed for triggerKeywords.successfulPattern in runtime evolution.json. Prefer editing evolution.json via the backlog workflow."
                  }
                }
              },
              "satisfactionCheck": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "enabled": { "type": "boolean", "default": true },
                  "everyTurns": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 1000,
                    "default": 10
                  }
                }
              },
              "missingIntent": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "enabled": { "type": "boolean", "default": true }
                }
              },
              "weakIntent": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "enabled": { "type": "boolean", "default": true },
                  "confidenceBelow": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 1,
                    "default": 0.5
                  }
                }
              },
              "behaviorFix": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "enabled": { "type": "boolean", "default": true },
                  "keywords": {
                    "type": "array",
                    "items": { "type": "string" },
                    "description": "Deprecated seed for triggerKeywords.behaviorFix in runtime evolution.json. Prefer editing evolution.json via the backlog workflow."
                  }
                }
              },
              "entityContext": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "enabled": { "type": "boolean", "default": true },
                  "keywords": {
                    "type": "array",
                    "items": { "type": "string" },
                    "description": "Deprecated seed for triggerKeywords.entityContext in runtime evolution.json. Prefer editing evolution.json via the backlog workflow."
                  }
                }
              }
            },
            "default": {}
          }
        },
        "default": {}
      }
    }
  }
}
