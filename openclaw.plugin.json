{
  "id": "intention-hint",
  "name": "Intention Hint",
  "description": "Pre-scans user intent before replies and injects routing hints via before_prompt_build hook.",
  "activation": {
    "onStartup": true
  },
  "skills": ["./skills"],
  "uiHints": {
    "model": {
      "label": "Scanner Model",
      "help": "Lightweight model for the intention scanner (e.g. google/gemini-3-flash). Leave empty to use the agent's default model."
    },
    "thinking": {
      "label": "Scanner Thinking",
      "help": "Thinking level for the intent classifier sub-agent."
    },
    "timeoutMs": {
      "label": "Scanner Timeout",
      "help": "Budget in milliseconds for the intention scanner sub-agent."
    }
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "agents": {
        "type": "array",
        "items": { "type": "string" },
        "description": "Agent IDs eligible for intention scanning.",
        "default": ["main"]
      },
      "intentDeny": {
        "type": "object",
        "description": "Per-agent deny-list for intent IDs injected into the intention classifier. Object keys are agent IDs or wildcard patterns; values are arrays of intent ID or wildcard patterns.",
        "additionalProperties": {
          "type": "array",
          "items": { "type": "string" }
        },
        "default": {}
      },
      "model": {
        "type": "string",
        "description": "Lightweight model for the intention scanner (e.g. google/gemini-3-flash). If null, falls back to the agent's default model.",
        "default": null
      },
      "modelFallback": {
        "type": "string",
        "description": "Fallback model when config.model cannot be resolved.",
        "default": null
      },
      "thinking": {
        "type": "string",
        "enum": [
          "off",
          "minimal",
          "low",
          "medium",
          "high",
          "xhigh",
          "adaptive",
          "max"
        ],
        "description": "Thinking level for the intent classifier sub-agent.",
        "default": "medium"
      },
      "allowedChatTypes": {
        "type": "array",
        "items": {
          "type": "string",
          "enum": ["direct", "group", "channel", "explicit"]
        },
        "description": "Which chat types are eligible.",
        "default": ["direct"]
      },
      "allowedChatIds": {
        "type": "array",
        "items": { "type": "string" },
        "description": "Allow-list of chat IDs.",
        "default": []
      },
      "deniedChatIds": {
        "type": "array",
        "items": { "type": "string" },
        "description": "Deny-list of chat IDs.",
        "default": []
      },
      "timeoutMs": {
        "type": "integer",
        "minimum": 250,
        "maximum": 120000,
        "description": "Budget in milliseconds for the intention scanner sub-agent.",
        "default": 10000
      },
      "queryMode": {
        "type": "string",
        "enum": ["message", "recent", "full"],
        "description": "Context sent to scanner: latest message only, recent turns, or full history.",
        "default": "recent"
      },
      "contextWindow": {
        "type": "object",
        "description": "Turn and character limits for recent conversation context.",
        "additionalProperties": false,
        "properties": {
          "user": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "turns": {
                "type": "integer",
                "minimum": 0,
                "maximum": 20,
                "default": 5
              },
              "chars": {
                "type": "integer",
                "minimum": 40,
                "maximum": 1000,
                "default": 220
              }
            }
          },
          "assistant": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "turns": {
                "type": "integer",
                "minimum": 0,
                "maximum": 10,
                "default": 5
              },
              "chars": {
                "type": "integer",
                "minimum": 40,
                "maximum": 1000,
                "default": 180
              }
            }
          }
        },
        "default": {}
      },
      "intentsDir": {
        "type": "string",
        "description": "Directory containing dynamic intent definitions (.md files with YAML frontmatter).",
        "default": "./intents"
      },
      "complexityPrompts": {
        "type": "object",
        "description": "Custom prompts for each complexity level.",
        "properties": {
          "low": {
            "type": "string",
            "description": "Custom prompt for low-complexity tasks (simple, quick questions).",
            "default": ""
          },
          "medium": {
            "type": "string",
            "description": "Custom prompt for medium-complexity tasks (standard multi-step work).",
            "default": ""
          },
          "high": {
            "type": "string",
            "description": "Custom prompt for high-complexity tasks (complex multi-file changes, architecture decisions).",
            "default": ""
          }
        },
        "additionalProperties": false,
        "default": {}
      },
      "evolution": {
        "type": "object",
        "description": "Optional post-turn Intent Self-Evolution reviews and plugin-local backlog.",
        "additionalProperties": false,
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": false
          },
          "model": {
            "type": "string",
            "description": "Dedicated model for Self-Evolution reviews."
          },
          "modelFallback": {
            "type": "string",
            "description": "Fallback model for Self-Evolution reviews."
          },
          "thinking": {
            "type": "string",
            "enum": [
              "off",
              "minimal",
              "low",
              "medium",
              "high",
              "xhigh",
              "adaptive",
              "max"
            ],
            "description": "Thinking level for the Self-Evolution review sub-agent.",
            "default": "medium"
          },
          "timeoutMs": {
            "type": "integer",
            "minimum": 250,
            "maximum": 120000,
            "default": 30000
          },
          "triggers": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "skillCandidate": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "enabled": { "type": "boolean", "default": true },
                  "toolCalls": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 100,
                    "default": 5
                  }
                }
              },
              "processGap": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "enabled": { "type": "boolean", "default": true },
                  "toolFailures": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 100,
                    "default": 2
                  }
                }
              },
              "satisfactionCheck": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "enabled": { "type": "boolean", "default": true },
                  "everyTurns": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 1000,
                    "default": 10
                  }
                }
              },
              "missingIntent": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "enabled": { "type": "boolean", "default": true }
                }
              },
              "weakIntent": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "enabled": { "type": "boolean", "default": true },
                  "confidenceBelow": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 1,
                    "default": 0.5
                  }
                }
              },
              "behaviorFix": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "enabled": { "type": "boolean", "default": true },
                  "keywords": {
                    "type": "array",
                    "items": { "type": "string" }
                  }
                }
              }
            },
            "default": {}
          }
        },
        "default": {}
      }
    }
  }
}
